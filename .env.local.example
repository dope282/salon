# ============================================================
# .env.local.example — энэ файлыг .env.local болгон хуулж бөглөнө үү.
# (.env.local-ийг git-д commit ХИЙХГҮЙ.)
# ============================================================

# ── Database (Datacom cPanel дээр localhost) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=hatantse_salon
DB_PASSWORD=
DB_NAME=hatantse_salon

# ── Auth ──
# AUTH_SECRET: урт санамсаргүй тэмдэгт (ж: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
AUTH_SECRET=
NEXT_PUBLIC_ADMIN_EMAILS=jaamaaj26@gmail.com,bdolmoosuren@gmail.com

# ── Сайтын URL (имэйл холбоос, QPay callback) ──
NEXT_PUBLIC_SITE_URL=https://hatantsetseglash.mn

# ── SMTP (нууц үг сэргээх имэйл — cPanel Email Account) ──
SMTP_HOST=mail.hatantsetseglash.mn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@hatantsetseglash.mn
SMTP_PASS=
SMTP_FROM=noreply@hatantsetseglash.mn

# ── QPay (merchant-аас авсан) ──
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=

# ── Дата шилжүүлэгт ЗӨВХӨН (scripts/migrate-from-supabase.mjs) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
